# Environment variables — copy to .env.local

# Gemini API (required for AI structuring + build suggestions)
GEMINI_API_KEY=your_gemini_api_key

# Supabase (optional — app works with in-memory seed data without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cron secret (protects /api/cron/scrape in production)
CRON_SECRET=your_random_secret
