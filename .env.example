# Environment variables — copy to .env.local

# Gemini API (required for AI structuring + build suggestions)
GEMINI_API_KEY=your_gemini_api_key
# Optional — defaults to gemini-2.5-flash (gemini-2.0-flash was shut down)
# GEMINI_MODEL=gemini-3.5-flash

# Supabase — required for feed data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Required for scraping (saves problems to DB). Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cron secret (protects /api/cron/scrape in production)
CRON_SECRET=your_random_secret
